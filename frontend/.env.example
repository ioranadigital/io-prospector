# Plantilla — copia a .env.local y rellena. Solo variables públicas (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000/api
# NEXT_PUBLIC_CLIENT_ID=

# SOLO servidor — nunca exponer con prefijo NEXT_PUBLIC_. Requerida por
# /api/admin/users (lib/supabase/admin.ts) para gestionar usuarios de Auth.
SUPABASE_SERVICE_ROLE_KEY=
