# ===========================
# SUPABASE Configuration
# ===========================
SUPABASE_URL=https://your-supabase-instance.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Public Supabase keys (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-instance.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# ===========================
# Network Configuration
# ===========================
# Frontend and Backend URLs (for CORS)
FRONTEND_URL=https://pros.iorana.dev
NEXT_PUBLIC_API_URL=https://api.pros.iorana.dev

# Internal Docker networking
BACKEND_INTERNAL_URL=http://backend:4000

# ===========================
# Server Ports
# ===========================
BACKEND_PORT=4000
FRONTEND_PORT=3002
REDIS_PORT=6379

# ===========================
# Node Environment
# ===========================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ===========================
# Redis Configuration
# ===========================
REDIS_URL=redis://redis:6379

# ===========================
# Bull Job Queue
# ===========================
BULL_QUEUE_PREFIX=io_prospector

# ===========================
# Email Configuration (for Nodemailer)
# ===========================
EMAIL_FROM=noreply@iorana.dev
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# ===========================
# Optional: Coolify Integration
# ===========================
# COOLIFY_FQDN=pros.iorana.dev
# COOLIFY_URL=https://coolify.iorana.dev

# ===========================
# Logging
# ===========================
LOG_LEVEL=info
